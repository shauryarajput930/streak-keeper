{
  "name": "streak-keeper",
  "version": "1.0.0",
  "description": "GitHub Streak Keeper - Multi-user dashboard",
  "scripts": {
    "dev": "concurrently \"pnpm run server\" \"pnpm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && pnpm start",
    "install:all": "pnpm install && cd client && pnpm install",
    "build": "cd client && pnpm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mongoose": "^8.0.3",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "serverless-http": "^4.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
